<publishing-template>
	<name>Print PDF</name>
	<description>For my portfolio's sample SOP.</description>
	<author>
		<name>Michael Sharber</name>
		<email>micshar1992@gmail.com</email>
	</author>

	<pdf>
		<tags>
			<tag>SOP</tag>
			<tag>example</tag>
		</tags>

		<resources>
			<css file="style.css" />
		</resources>
		
		<xslt>
			<extension id="SOPXSLT" file="SOPXSLT.xsl" />
		</xslt>

	</pdf>
</publishing-template>